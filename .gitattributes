# Normalize line endings: store text as LF in the repo.
* text=auto eol=lf

# These MUST stay LF (they run on the Linux server) regardless of platform.
*.sh        text eol=lf
*.service   text eol=lf
*.conf      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf

# Binary files — never normalize.
*.png       binary
*.ico       binary
*.jpg       binary
